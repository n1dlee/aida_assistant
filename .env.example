# AIDA Environment Variables
# Copy this file to .env and fill in your keys.
# Never commit .env to version control.

# --- Cloud LLM keys (at least one required for cloud fallback) ---
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# --- Local model (Ollama must be running) ---
OLLAMA_BASE_URL=http://localhost:11434
AIDA_LOCAL_MODEL=gemma4:31b

# --- Cloud routing threshold (0.0 = always local, 1.0 = always cloud) ---
AIDA_CLOUD_THRESHOLD=0.4

# --- Voice ---
WHISPER_MODEL=small
AIDA_WAKE_WORD=hey aida
AIDA_TTS_RATE=175
PIPER_VOICE=en_US-lessac-medium
